<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Rdpeek.Companion.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Rdpeek.Companion.WinUI"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <Grid Padding="16" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12">
            <TextBlock Text="RDPeek" FontSize="26" FontWeight="SemiBold" VerticalAlignment="Center" />
            <Button Content="Copy agent-install command" Command="{x:Bind Vm.CopyInstallCommand}" VerticalAlignment="Center" />
            <Button Content="Refresh" Command="{x:Bind Vm.RefreshCommand}" VerticalAlignment="Center" />
        </StackPanel>

        <muxc:NavigationView Grid.Row="1"
                             PaneDisplayMode="Top"
                             IsBackButtonVisible="Collapsed"
                             IsSettingsVisible="False"
                             SelectionChanged="OnNavChanged">
            <muxc:NavigationView.MenuItems>
                <muxc:NavigationViewItem Content="Dashboard" Tag="dash" IsSelected="True" />
                <muxc:NavigationViewItem Content="Network" Tag="net" />
                <muxc:NavigationViewItem Content="Sessions" Tag="sess" />
                <muxc:NavigationViewItem Content="Services" Tag="svc" />
                <muxc:NavigationViewItem Content="Channels" Tag="chan" />
            </muxc:NavigationView.MenuItems>

            <Grid Margin="0,12,0,0">
                <!-- ===================== DASHBOARD ===================== -->
                <Grid x:Name="DashView" RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="170" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- connections -->
                    <Border Grid.Row="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Padding="12,8" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0.28*" />
                                    <ColumnDefinition Width="0.30*" />
                                    <ColumnDefinition Width="0.42*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Host" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1" Text="Agent" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="2" Text="Window" FontWeight="SemiBold" />
                            </Grid>
                            <ListView Grid.Row="1" ItemsSource="{x:Bind Vm.Connections}"
                                      SelectedItem="{x:Bind Vm.SelectedConnection, Mode=TwoWay}"
                                      SelectionMode="Single">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="12,6" />
                                        <Setter Property="MinHeight" Value="0" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="local:ConnectionRow">
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="0.28*" />
                                                <ColumnDefinition Width="0.30*" />
                                                <ColumnDefinition Width="0.42*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{x:Bind Host, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1" Text="{x:Bind Agent, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="2" Text="{x:Bind Window, Mode=OneWay}" TextTrimming="CharacterEllipsis" Opacity="0.8" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>

                    <!-- host header + perf strip -->
                    <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="14,10">
                        <StackPanel Spacing="6">
                            <TextBlock Text="{x:Bind Vm.HostHeader, Mode=OneWay}" TextWrapping="Wrap"
                                       FontFamily="Consolas" LineHeight="20" />
                            <TextBlock Text="{x:Bind Vm.PerfText, Mode=OneWay}" TextWrapping="Wrap"
                                       FontFamily="Consolas" Opacity="0.85" />
                        </StackPanel>
                    </Border>

                    <!-- processes -->
                    <Border Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Padding="12,8" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0.12*" />
                                    <ColumnDefinition Width="0.34*" />
                                    <ColumnDefinition Width="0.34*" />
                                    <ColumnDefinition Width="0.20*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="PID" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1" Text="Image" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="2" Text="User" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="3" Text="Working set" FontWeight="SemiBold" />
                            </Grid>
                            <ListView Grid.Row="1" ItemsSource="{x:Bind Vm.Processes}" SelectionMode="None">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="12,3" />
                                        <Setter Property="MinHeight" Value="0" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="local:ProcRow">
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="0.12*" />
                                                <ColumnDefinition Width="0.34*" />
                                                <ColumnDefinition Width="0.34*" />
                                                <ColumnDefinition Width="0.20*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{x:Bind Pid}" />
                                            <TextBlock Grid.Column="1" Text="{x:Bind Image}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="2" Text="{x:Bind User}" TextTrimming="CharacterEllipsis" Opacity="0.8" />
                                            <TextBlock Grid.Column="3" Text="{x:Bind Mem}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ===================== CHANNELS ===================== -->
                <Grid x:Name="ChanView" Visibility="Collapsed">
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Margin="12,10,12,4" Opacity="0.8"
                                       Text="Dynamic Virtual Channels configured on this client (mstsc):" />
                            <Grid Grid.Row="1" Padding="12,4" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0.18*" />
                                    <ColumnDefinition Width="0.16*" />
                                    <ColumnDefinition Width="0.20*" />
                                    <ColumnDefinition Width="0.46*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Channel" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1" Text="Kind" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="2" Text="Activation" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="3" Text="Module / description" FontWeight="SemiBold" />
                            </Grid>
                            <ListView Grid.Row="1" Margin="0,32,0,0" ItemsSource="{x:Bind Vm.Channels}" SelectionMode="None">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="12,5" />
                                        <Setter Property="MinHeight" Value="0" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="local:ChannelRow">
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="0.18*" />
                                                <ColumnDefinition Width="0.16*" />
                                                <ColumnDefinition Width="0.20*" />
                                                <ColumnDefinition Width="0.46*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1" Text="{x:Bind Kind}" Opacity="0.8" />
                                            <TextBlock Grid.Column="2" Text="{x:Bind Activation}" Opacity="0.8" />
                                            <TextBlock Grid.Column="3" Text="{x:Bind Module}" TextTrimming="CharacterEllipsis" Opacity="0.8" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ===================== NETWORK ===================== -->
                <Grid x:Name="NetView" Visibility="Collapsed">
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                            <Grid Grid.Row="0" Padding="12,8" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0.24*" /><ColumnDefinition Width="0.24*" />
                                    <ColumnDefinition Width="0.16*" /><ColumnDefinition Width="0.36*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Local" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1" Text="Remote" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="2" Text="State" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="3" Text="Process" FontWeight="SemiBold" />
                            </Grid>
                            <ListView Grid.Row="1" ItemsSource="{x:Bind Vm.Network}" SelectionMode="None">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="12,3" /><Setter Property="MinHeight" Value="0" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="local:NetRow">
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="0.24*" /><ColumnDefinition Width="0.24*" />
                                                <ColumnDefinition Width="0.16*" /><ColumnDefinition Width="0.36*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{x:Bind Local}" FontFamily="Consolas" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1" Text="{x:Bind Remote}" FontFamily="Consolas" Opacity="0.8" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="2" Text="{x:Bind State}" />
                                            <TextBlock Grid.Column="3" Text="{x:Bind Process}" TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ===================== SESSIONS ===================== -->
                <Grid x:Name="SessView" Visibility="Collapsed">
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                            <Grid Grid.Row="0" Padding="12,8" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0.08*" /><ColumnDefinition Width="0.18*" />
                                    <ColumnDefinition Width="0.30*" /><ColumnDefinition Width="0.16*" /><ColumnDefinition Width="0.28*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="ID" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1" Text="Station" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="2" Text="User" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="3" Text="State" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="4" Text="Client" FontWeight="SemiBold" />
                            </Grid>
                            <ListView Grid.Row="1" ItemsSource="{x:Bind Vm.Sessions}" SelectionMode="None">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="12,4" /><Setter Property="MinHeight" Value="0" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="local:SessionRow">
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="0.08*" /><ColumnDefinition Width="0.18*" />
                                                <ColumnDefinition Width="0.30*" /><ColumnDefinition Width="0.16*" /><ColumnDefinition Width="0.28*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{x:Bind Id}" />
                                            <TextBlock Grid.Column="1" Text="{x:Bind Station}" />
                                            <TextBlock Grid.Column="2" Text="{x:Bind User}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="3" Text="{x:Bind State}" />
                                            <TextBlock Grid.Column="4" Text="{x:Bind Client}" Opacity="0.8" TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ===================== SERVICES ===================== -->
                <Grid x:Name="SvcView" Visibility="Collapsed">
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                            <Grid Grid.Row="0" Padding="12,8" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0.22*" /><ColumnDefinition Width="0.12*" />
                                    <ColumnDefinition Width="0.12*" /><ColumnDefinition Width="0.54*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Service" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1" Text="Status" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="2" Text="Start" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="3" Text="Display name" FontWeight="SemiBold" />
                            </Grid>
                            <ListView Grid.Row="1" ItemsSource="{x:Bind Vm.Services}" SelectionMode="None">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="12,3" /><Setter Property="MinHeight" Value="0" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="local:ServiceRow">
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="0.22*" /><ColumnDefinition Width="0.12*" />
                                                <ColumnDefinition Width="0.12*" /><ColumnDefinition Width="0.54*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1" Text="{x:Bind Status}" />
                                            <TextBlock Grid.Column="2" Text="{x:Bind StartType}" Opacity="0.8" />
                                            <TextBlock Grid.Column="3" Text="{x:Bind Display}" TextTrimming="CharacterEllipsis" Opacity="0.8" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </muxc:NavigationView>

        <TextBlock Grid.Row="2" Text="{x:Bind Vm.Status, Mode=OneWay}" Opacity="0.9" />
    </Grid>
</Window>
